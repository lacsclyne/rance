{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/cards.schema.json",
  "title": "Card collection",
  "type": "object",
  "required": ["version", "cards"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "rarity", "cost", "target", "effects"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["attack", "skill", "power"]
          },
          "rarity": {
            "type": "string",
            "enum": ["starter", "common", "uncommon", "rare"]
          },
          "cost": { "type": "integer", "minimum": 0 },
          "target": {
            "type": "string",
            "enum": ["self", "ally", "enemy", "all_enemies"]
          },
          "card_art_asset_id": { "$ref": "#/$defs/assetId" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "effects": {
            "type": "array",
            "items": { "$ref": "#/$defs/effect" },
            "minItems": 1
          }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "assetId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "effect": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["damage", "block", "heal", "draw", "apply_status", "gain_energy"]
        },
        "amount": { "type": "integer", "minimum": 0 },
        "status_id": { "$ref": "#/$defs/contentId" },
        "duration": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
