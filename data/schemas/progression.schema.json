{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/progression.schema.json",
  "title": "Progression collection",
  "type": "object",
  "required": ["version", "progression_nodes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "progression_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "requires", "unlocks"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "requires": {
            "type": "array",
            "items": { "$ref": "#/$defs/contentId" },
            "uniqueItems": true
          },
          "unlocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "content_id"],
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["character", "card", "skill", "encounter", "quest"]
                },
                "content_id": { "$ref": "#/$defs/contentId" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    }
  }
}
