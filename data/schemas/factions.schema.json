{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/factions.schema.json",
  "title": "Faction collection",
  "type": "object",
  "required": ["version", "factions"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "factions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "alignment", "color"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "alignment": {
            "type": "string",
            "enum": ["ally", "neutral", "enemy"]
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "summary": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    }
  }
}
