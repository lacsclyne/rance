{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/quests.schema.json",
  "title": "Quest collection",
  "type": "object",
  "required": ["version", "quests"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "quests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "objective", "encounter_ids", "reward_pool_id"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "encounter_ids": {
            "type": "array",
            "items": { "$ref": "#/$defs/contentId" },
            "minItems": 1,
            "uniqueItems": true
          },
          "reward_pool_id": { "$ref": "#/$defs/contentId" },
          "progression_reward_id": { "$ref": "#/$defs/contentId" }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    }
  }
}
