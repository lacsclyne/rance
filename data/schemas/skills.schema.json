{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/skills.schema.json",
  "title": "Skill collection",
  "type": "object",
  "required": ["version", "skills"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "trigger", "description"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "trigger": {
            "type": "string",
            "enum": ["battle_start", "turn_start", "card_played", "on_damage", "active"]
          },
          "description": { "type": "string", "minLength": 1 },
          "status_ids": {
            "type": "array",
            "items": { "$ref": "#/$defs/contentId" },
            "uniqueItems": true
          },
          "numeric_value": { "type": "integer" }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    }
  }
}
