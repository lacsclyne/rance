{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacsclyne.local/schemas/statuses.schema.json",
  "title": "Status collection",
  "type": "object",
  "required": ["version", "statuses"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "polarity", "stack_rule", "default_duration", "description"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/contentId" },
          "name": { "type": "string", "minLength": 1 },
          "polarity": {
            "type": "string",
            "enum": ["buff", "debuff"]
          },
          "stack_rule": {
            "type": "string",
            "enum": ["add", "replace", "intensity"]
          },
          "default_duration": { "type": "integer", "minimum": 0 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    }
  }
}
